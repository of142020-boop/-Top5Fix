---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'انضم كصنايعي — Top5Fix';
const pageDesc = 'انضم إلى قائمة أفضل الفنيين والصنايعية في مصر وزود دخلك مع Top5Fix.';

const waLink = 'https://wa.me/201000000000?text=' + encodeURIComponent('أهلاً Top5Fix، أريد الانضمام كصنايعي إلى المنصة.');
---

<BaseLayout title={pageTitle} description={pageDesc} canonical="https://top5fix.com/join">
  <!-- ══ Nav ══ -->
  <nav class="bg-white/95 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-gray-900 font-black text-xl">
        <span class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center text-white shadow-sm">🔧</span>
        Top5<span class="text-blue-600">Fix</span>
      </a>
      <a href="/" class="text-sm font-bold text-gray-500 hover:text-blue-600 transition-colors">العودة للرئيسية</a>
    </div>
  </nav>

  <main class="bg-gray-50 pt-16 pb-24">
    <div class="max-w-3xl mx-auto px-4">
      
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-black text-gray-900 mb-6 leading-tight">
          انضم إلى قائمة أفضل الصنايعية<br/>في <span class="text-blue-600">القاهرة والجيزة</span>
        </h1>
        <p class="text-xl text-gray-600 font-medium max-w-xl mx-auto leading-relaxed">
          نحن نوصلك بالعملاء الذين يبحثون عن الجودة والموثوقية. انضم إلينا اليوم وضاعف حجم عملك بدون عمولات مخفية.
        </p>
      </div>

      <!-- Benefits -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-16">
        <div class="bg-white p-8 rounded-3xl border border-gray-200 shadow-sm text-center">
          <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6">🚀</div>
          <h3 class="text-xl font-black text-gray-900 mb-3">عملاء أكثر باستمرار</h3>
          <p class="text-gray-600 font-medium">الآلاف يزورون موقعنا يومياً للبحث عن فنيين موثوقين، كن الخيار الأول لهم.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl border border-gray-200 shadow-sm text-center">
          <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6">💰</div>
          <h3 class="text-xl font-black text-gray-900 mb-3">احتفظ بأرباحك كاملة</h3>
          <p class="text-gray-600 font-medium">العميل يتواصل معك مباشرة عبر الهاتف أو الواتساب، نحن لا نتدخل في اتفاقياتكم.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl border border-gray-200 shadow-sm text-center sm:col-span-2">
          <div class="w-16 h-16 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6">⭐</div>
          <h3 class="text-xl font-black text-gray-900 mb-3">ابنِ سمعتك الرقمية</h3>
          <p class="text-gray-600 font-medium max-w-lg mx-auto">احصل على تقييمات حقيقية من عملائك تزيد من ثقة العملاء الجدد بك وتجعلك في صدارة القائمة.</p>
        </div>
      </div>

      <!-- Requirements -->
      <div class="bg-white p-8 sm:p-12 rounded-[32px] border border-gray-200 shadow-sm mb-16">
        <h2 class="text-2xl font-black text-gray-900 mb-8 text-center">شروط الانضمام لمنصة Top5Fix</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 mt-0.5 font-bold">1</span>
            <div>
              <h4 class="font-bold text-gray-900 text-lg">خبرة مثبتة في مجالك</h4>
              <p class="text-gray-600 text-sm mt-1 font-medium">يجب أن تمتلك خبرة حقيقية وسابقة أعمال يمكن التحقق منها.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 mt-0.5 font-bold">2</span>
            <div>
              <h4 class="font-bold text-gray-900 text-lg">الالتزام بالمواعيد والأمانة</h4>
              <p class="text-gray-600 text-sm mt-1 font-medium">أساس تقييم الفني في موقعنا هو الأمانة والمواعيد الدقيقة مع العملاء.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 mt-0.5 font-bold">3</span>
            <div>
              <h4 class="font-bold text-gray-900 text-lg">إثبات الشخصية</h4>
              <p class="text-gray-600 text-sm mt-1 font-medium">تقديم صورة البطاقة الشخصية لتوثيق الحساب وضمان الأمان للعملاء.</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <h2 class="text-2xl font-black text-gray-900 mb-6">جاهز لتكون من أفضل 5 فنيين؟</h2>
        <a 
          href={waLink} 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xl px-10 py-5 rounded-2xl shadow-lg transition-transform hover:-translate-y-1"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          تواصل معنا للتسجيل الآن
        </a>
      </div>

    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <div class="flex flex-wrap justify-center gap-6 font-bold text-gray-500 mb-6">
        <a href="/" class="hover:text-blue-600 transition-colors">الرئيسية</a>
        <a href="/about" class="hover:text-blue-600 transition-colors">من نحن</a>
        <a href="/join" class="text-blue-600">انضم كصنايعي</a>
        <a href="/contact" class="hover:text-blue-600 transition-colors">تواصل معنا</a>
        <a href="/privacy" class="hover:text-blue-600 transition-colors">سياسة الخصوصية</a>
        <a href="/terms" class="hover:text-blue-600 transition-colors">شروط الاستخدام</a>
      </div>
      <p class="text-gray-400 font-semibold text-sm">© {new Date().getFullYear()} Top5Fix.com.</p>
    </div>
  </footer>
</BaseLayout>
