---
export interface Props {
  name: string;
  phone: string;
  rating: number;
  reviewCount: number;
  governorate: 'القاهرة' | 'الجيزة';
  districts: string[];
  avatar: string;
  profession: string;
  verified: boolean;
  responseTime: string;
  priceFrom: number;
  completedJobs: number;
  clientReview: string;
  rank?: number;
  isActive?: boolean;
  subscriptionEndDate?: string;
}

const {
  name, phone, rating, reviewCount, governorate, districts,
  avatar, profession, verified, responseTime, priceFrom,
  completedJobs, clientReview, rank, isActive, subscriptionEndDate
} = Astro.props;

const isCairo   = governorate === 'القاهرة';
const fullStars  = Math.floor(rating);
const hasHalf    = rating - fullStars >= 0.5;

// WhatsApp link — opens chat with a pre-filled message
const waMsg  = encodeURIComponent(`أهلاً، وجدتك على Top5Fix وأريد الاستفسار عن خدمة ${profession}`);
const waLink = `https://wa.me/2${phone}?text=${waMsg}`;

const isSuspended = isActive === false || 
  (subscriptionEndDate ? new Date(subscriptionEndDate).getTime() < new Date().getTime() : false);
---

<article class="bg-white border border-gray-200 rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative flex flex-col group h-full">
  
  <!-- Header Background -->
  <div class="h-28 bg-gradient-to-br from-blue-50 to-blue-100/50 relative">
    <!-- Rank badge (top-left) -->
    {rank && rank <= 3 && (
      <div class="absolute top-0 start-0 z-20">
        <div class={`px-4 py-1.5 text-sm font-black rounded-br-2xl shadow-sm
          ${rank === 1 ? 'bg-amber-400 text-amber-950' :
            rank === 2 ? 'bg-gray-200 text-gray-800' :
                         'bg-orange-200 text-orange-900'}`}>
          #{rank} {rank === 1 ? '🥇' : rank === 2 ? '🥈' : '🥉'}
        </div>
      </div>
    )}

    <!-- Verified Badge (top-right) -->
    {verified && (
      <div class="absolute top-4 end-4 z-10">
        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-white text-emerald-600 shadow-sm border border-emerald-100">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
          موثّق
        </span>
      </div>
    )}
  </div>

  <!-- Avatar overlapping header -->
  <div class="relative -mt-14 flex justify-center z-10 px-4">
    <div class="relative">
      <img
        src={avatar}
        alt={`${name} — ${profession}`}
        class="w-28 h-28 rounded-full object-cover border-4 border-white shadow-md bg-white"
        loading="lazy"
        width="112"
        height="112"
      />
      <!-- Online Indicator -->
      <span class={`absolute bottom-1 end-2 w-5 h-5 border-4 border-white rounded-full ${isSuspended ? 'bg-gray-400' : 'bg-emerald-500'}`} title={isSuspended ? 'غير متاح حالياً' : 'متاح الآن'}></span>
    </div>
  </div>

  <!-- Card body -->
  <div class="flex flex-col flex-1 p-6 text-center items-center gap-4">

    <!-- Name + profession -->
    <div>
      <h2 class="text-xl font-black text-gray-900 leading-snug mb-1">{name}</h2>
      <p class="text-blue-600 text-sm font-bold">{profession}</p>
    </div>

    <!-- Rating -->
    <div class="flex items-center gap-1.5 bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100" aria-label={`تقييم ${rating} من 5 بناءً على ${reviewCount} تقييم`}>
      <span class="text-amber-500 font-black">{rating.toFixed(1)}</span>
      <div class="flex">
        {Array.from({ length: 5 }, (_, i) => (
          <svg
            class={`w-4 h-4 ${
              i < fullStars ? 'text-amber-400' :
              i === fullStars && hasHalf ? 'text-amber-300' :
              'text-gray-300'
            }`}
            fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <span class="text-gray-500 text-xs font-semibold">({reviewCount})</span>
    </div>

    <!-- CTAs -->
    <div class="w-full grid grid-cols-2 gap-2 mt-auto pt-4">
      {isSuspended ? (
        <div class="col-span-2 py-3 rounded-xl font-bold text-sm bg-gray-100 text-gray-500 border border-gray-200 cursor-not-allowed flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          الفني غير متاح حاليا
        </div>
      ) : (
        <>
          <!-- Call button -->
          <a
            href={`tel:${phone}`}
            class="flex items-center justify-center gap-1.5 py-3 rounded-xl font-bold text-sm
                   bg-blue-600 hover:bg-blue-700 text-white shadow-md shadow-blue-600/20
                   transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            اتصل
          </a>
          <!-- WhatsApp button -->
          <a
            href={waLink}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-1.5 py-3 rounded-xl font-bold text-sm
                   bg-[#25D366] hover:bg-[#1ebe5c] text-white shadow-md shadow-green-500/20
                   transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            واتساب
          </a>
        </>
      )}
    </div>

  </div>
</article>
