---
export interface Props {
  name: string;
  phone: string;
  whatsapp?: string;
  governorate: 'القاهرة' | 'الجيزة';
  avatar: string;
  profession: string;
  isActive?: boolean;
  accountStatus?: string;
  color?: string;
}

const {
  name, phone, whatsapp, governorate, avatar, profession, isActive, accountStatus, color = 'blue'
} = Astro.props;

// Use whatsapp if available, otherwise fallback to phone
const waNumber = whatsapp || phone;

const waMsg  = encodeURIComponent(`أهلاً، وجدتك على Top5Fix وأريد الاستفسار عن خدمة ${profession}`);
const waLink = `https://wa.me/2${waNumber}?text=${waMsg}`;

const isSuspended = accountStatus === 'موقوف' || isActive === false;

const colorMap: Record<string, string> = {
  blue: 'border-blue-400 shadow-blue-100 from-blue-50 to-blue-100/50',
  emerald: 'border-emerald-400 shadow-emerald-100 from-emerald-50 to-emerald-100/50',
  amber: 'border-amber-400 shadow-amber-100 from-amber-50 to-amber-100/50',
  rose: 'border-rose-400 shadow-rose-100 from-rose-50 to-rose-100/50',
  slate: 'border-slate-400 shadow-slate-100 from-slate-50 to-slate-100/50',
  purple: 'border-purple-400 shadow-purple-100 from-purple-50 to-purple-100/50',
  cyan: 'border-cyan-400 shadow-cyan-100 from-cyan-50 to-cyan-100/50',
  teal: 'border-teal-400 shadow-teal-100 from-teal-50 to-teal-100/50',
  orange: 'border-orange-400 shadow-orange-100 from-orange-50 to-orange-100/50',
  yellow: 'border-yellow-400 shadow-yellow-100 from-yellow-50 to-yellow-100/50',
  indigo: 'border-indigo-400 shadow-indigo-100 from-indigo-50 to-indigo-100/50',
};

const themeClasses = colorMap[color] || colorMap.blue;
const borderClass = themeClasses.split(' ').filter(c => c.startsWith('border-'))[0];
const shadowClass = themeClasses.split(' ').filter(c => c.startsWith('shadow-'))[0];
const bgClasses = themeClasses.split(' ').filter(c => c.startsWith('from-') || c.startsWith('to-')).join(' ');
---

<article class={`bg-white border-[3px] ${borderClass} ${shadowClass} rounded-[24px] overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative flex flex-col group h-full`}>
  
  <!-- Header Background -->
  <div class={`h-24 bg-gradient-to-br ${bgClasses} relative`}>
    <!-- Governorate Badge -->
    <div class="absolute top-4 start-4 z-10">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-white/80 text-gray-800 shadow-sm border border-white/50 backdrop-blur-sm">
        📍 {governorate}
      </span>
    </div>
  </div>

  <!-- Avatar overlapping header -->
  <div class="relative -mt-12 flex justify-center z-10 px-4">
    <div class="relative">
      <img
        src={avatar}
        alt={`${name} — ${profession}`}
        class={`w-24 h-24 rounded-full object-cover border-4 border-white shadow-md bg-white`}
        loading="lazy"
        width="96"
        height="96"
      />
      <!-- Online Indicator -->
      <span class={`absolute bottom-1 end-1 w-5 h-5 border-4 border-white rounded-full ${isSuspended ? 'bg-gray-400' : 'bg-emerald-500'}`} title={isSuspended ? 'الفني غير متاح حاليا' : 'متاح الآن'}></span>
    </div>
  </div>

  <!-- Card body -->
  <div class="flex flex-col flex-1 p-6 text-center items-center justify-between gap-6">

    <!-- Name + profession -->
    <div>
      <h2 class="text-2xl font-black text-gray-900 leading-snug mb-1">{name}</h2>
      <p class="text-gray-500 font-bold">{profession}</p>
    </div>

    <!-- CTAs -->
    <div class="w-full grid grid-cols-2 gap-3 mt-auto">
      {isSuspended ? (
        <div class="col-span-2 py-3.5 rounded-xl font-bold text-sm bg-gray-100 text-gray-500 border border-gray-200 cursor-not-allowed flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          الفني غير متاح حاليا
        </div>
      ) : (
        <>
          <!-- Call button -->
          <a
            href={`tel:${phone}`}
            class="flex items-center justify-center gap-2 py-3.5 rounded-xl font-bold text-[15px]
                   bg-blue-600 hover:bg-blue-700 text-white shadow-md shadow-blue-600/20
                   transition-all duration-200"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            اتصل
          </a>
          <!-- WhatsApp button -->
          <a
            href={waLink}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 py-3.5 rounded-xl font-bold text-[15px]
                   bg-[#25D366] hover:bg-[#1ebe5c] text-white shadow-md shadow-green-500/20
                   transition-all duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            واتساب
          </a>
        </>
      )}
    </div>

  </div>
</article>
